CONFIG_COMPILER_OPTIMIZATION_SIZE=y

## PSRAM Takt auf 40MHz senken (behebt EMI und Bus-Konflikte)
# CONFIG_SPIRAM_SPEED_40M=y
## CONFIG_SPIRAM_SPEED_80M is not set

## CPU Takt leicht senken (optional, hilft gegen Brownouts bei WiFi-Spitzen)
## CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240 is not set
# CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_160=y

## WiFi/LWIP Speicher NICHT in den PSRAM (entlastet den Bus während WiFi-Init)
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=n
